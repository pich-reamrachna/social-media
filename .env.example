# Database
# Runtime app traffic: use Neon pooled connection string (`-pooler` host)
DATABASE_URL="postgresql://user:password@host-pooler:5432/db-name?sslmode=require"
# Drizzle migrations/studio: use direct Neon connection string (no `-pooler` host)
DATABASE_URL_MIGRATION="postgresql://user:password@host:5432/db-name?sslmode=require"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
CRON_SECRET=""

# Email verification
# In local development, verification links are logged if these are blank.
EMAIL_FROM=""
EMAIL_REPLY_TO=""
RESEND_API_KEY=""

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
